# --- CONFIGURACIÓN DEL SERVIDOR ---
SERVER_PORT=8080
CONTEXT_PATH=/api/v1

# --- BASE DE DATOS ---
DB_URL=jdbc:mysql://localhost:3306/BD_DOCUFISE_DEV?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=12345678

# --- SEGURIDAD (JWT) ---
# Se recomienda una clave de al menos 512 bits para producción
JWT_SECRET=docufise-secret-key-2026-fise-project-springboot-jwt-authentication-secure-key-min-512-bits
JWT_EXPIRATION=86400000

# --- ALMACENAMIENTO DE ARCHIVOS ---
# Tipos: local, sftp, s3
STORAGE_TYPE=local
STORAGE_BASE_PATH=uploads

# --- CONFIGURACIÓN SFTP (Opcional) ---
SFTP_HOST=localhost
SFTP_PORT=22
SFTP_USER=docufise
SFTP_PASS=
SFTP_REMOTE_PATH=/uploads/docufise

# --- CONFIGURACIÓN AWS S3 (Opcional) ---
S3_BUCKET=docufise-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- PARÁMETROS DE NEGOCIO ---
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_MINUTES=15
